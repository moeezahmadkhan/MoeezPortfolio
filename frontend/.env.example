# Web3Forms public access key — get one (no signup) at https://web3forms.com/#start
# Copy this file to .env and paste your key. Web3Forms keys are designed to be
# public/client-side, so VITE_ exposure is intentional.
VITE_WEB3FORMS_KEY=your-web3forms-access-key

# OpenRouter API key for the "Familiar" AI chat. Server-side only — do NOT prefix
# with VITE_ (that would expose it in the client bundle). Set this in your local
# .env AND in Vercel's project Environment Variables. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
